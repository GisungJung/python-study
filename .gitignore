# 1. 파이썬 실행 시 생성되는 임시 파일 (컴파일된 코드)
__pycache__
.py[cod]
$py.class

# 2. 가상 환경 (Virtual Environments) - 프로젝트마다 환경이 다르므로 제외
venv
.venv
env
bin
lib

# 3. 라이브러리 설치 시 생성되는 파일 및 배포 관련
build
develop-eggs
dist
downloads
eggs
